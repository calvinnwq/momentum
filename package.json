{
  "name": "@calvinnwq/momentum",
  "version": "0.20.0",
  "private": true,
  "description": "TypeScript CLI scaffold for Momentum autonomous repo-work orchestration.",
  "type": "module",
  "bin": {
    "momentum": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "skills/momentum",
    "ARCHITECTURE.md",
    "CHANGELOG.md",
    "MOMENTUM.md",
    "README.md",
    "SPEC.md",
    "VISION.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "docs": "python3 -m http.server 8080 --bind 127.0.0.1 --directory docs",
    "test": "vitest run --config vitest.fast.config.ts",
    "test:fast": "vitest run --config vitest.fast.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:full": "pnpm test:fast && pnpm test:integration",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "lint": "oxlint src test --deny-warnings",
    "format": "node scripts/prettier-changed.mjs --write",
    "format:check": "node scripts/prettier-changed.mjs --check"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.3",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
