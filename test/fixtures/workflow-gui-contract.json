      "failedRecovery": {
        "emit": true,
        "reason": "recovery_required",
        "disposition": "recover",
        "phase": "blocked",
        "recommendedAction": "operator_decision",
        "recommendedActionPolicy": {
          "action": "operator_decision",
          "authority": "human_required",
          "risk": "medium"
        },
        "nextPollSeconds": 30,
        "quietForSeconds": 0,
        "quietThresholdSeconds": 3600,
        "stuckRisk": "high",
        "cleanup": "none",
        "humanAction": null,
        "nextActionCode": "rerun_failed_step",
        "activeStep": {
          "stepId": "implementation",
          "state": "failed"
        }
      },
      "idle": {
        "emit": true,
        "reason": "idle",
        "disposition": "wait",
        "phase": "idle",
        "recommendedAction": "poll",
        "recommendedActionPolicy": {
          "action": "watch_recheck",
          "authority": "auto_allowed",
          "risk": "low"
        },
        "nextPollSeconds": 15,
        "quietForSeconds": 0,
        "quietThresholdSeconds": 900,
        "stuckRisk": "medium",
        "cleanup": "none",
        "activeStep": null,
        "humanAction": null
      }
