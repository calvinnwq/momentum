    "humanActionCodes": ["approve", "resolve_gate", "clear_recovery"],
    "recommendedActions": ["poll", "approve", "operator_decision", "recover", "release"],
    "dispositions": ["wait", "report", "recover"],
    "phases": [
      "advancing",
      "idle",
      "awaiting_approval",
