    "scenarios": {
      "progress": {
        "emit": true,
        "reason": "in_progress",
        "disposition": "wait",
        "phase": "advancing",
        "recommendedAction": "poll",
        "recommendedActionPolicy": {
          "action": "watch_recheck",
          "authority": "auto_allowed",
          "risk": "low"
        },
        "nextPollSeconds": 15,
        "quietForSeconds": 0,
        "quietThresholdSeconds": 900,
        "stuckRisk": "low",
        "cleanup": "none",
        "activeStep": {
          "stepId": "implementation",
          "state": "running"
        }
      },
      "approval": {
        "emit": true,
        "reason": "awaiting_approval",
        "disposition": "report",
        "phase": "awaiting_approval",
        "recommendedAction": "approve",
        "recommendedActionPolicy": {
          "action": "approval_decision",
          "authority": "human_required",
          "risk": "medium"
        },
        "nextPollSeconds": 30,
        "quietForSeconds": 0,
        "quietThresholdSeconds": 1800,
        "stuckRisk": "medium",
        "cleanup": "none",
        "humanAction": {
          "code": "approve",
          "command": "momentum workflow run approve ${runId} --approval-boundary through-implementation --phrase \"approve plan ${runId} through-implementation\""
        }
      },
      "manualRecovery": {
        "emit": true,
        "reason": "recovery_required",
        "disposition": "recover",
        "phase": "blocked",
        "recommendedAction": "recover",
        "recommendedActionPolicy": {
          "action": "clear_recovery",
          "authority": "human_required",
          "risk": "high"
        },
        "nextPollSeconds": 30,
        "quietForSeconds": 0,
        "quietThresholdSeconds": 3600,
        "stuckRisk": "high",
        "cleanup": "none",
        "humanAction": {
          "code": "clear_recovery",
          "command": "momentum workflow run clear-recovery ${runId}"
        }
      },
      "stuckRisk": {
        "emit": true,
        "reason": "stuck_risk",
        "disposition": "wait",
        "phase": "advancing",
        "recommendedAction": "poll",
        "recommendedActionPolicy": {
          "action": "watch_recheck",
          "authority": "auto_allowed",
          "risk": "low"
        },
        "nextPollSeconds": 15,
        "quietForSecondsMin": 900,
        "quietThresholdSeconds": 900,
        "stuckRisk": "medium",
        "cleanup": "none",
        "nextActionCode": "resume_running",
        "activeStep": {
          "stepId": "implementation",
          "state": "running"
        },
        "humanAction": null
      },
      "terminalSuccess": {
        "emit": true,
        "reason": "terminal_succeeded",
        "disposition": "report",
        "phase": "terminal",
        "recommendedAction": "release",
        "recommendedActionPolicy": {
          "action": "release_monitor",
          "authority": "auto_allowed",
          "risk": "low"
        },
        "nextPollSeconds": 0,
        "quietForSeconds": 0,
        "quietThresholdSeconds": 0,
        "stuckRisk": "low",
        "cleanup": "release",
        "nextActionCode": "no_action",
        "humanAction": null,
        "activeStep": null
      },
      "terminalCanceled": {
        "emit": true,
        "reason": "terminal_canceled",
        "disposition": "report",
        "phase": "terminal",
        "recommendedAction": "release",
        "recommendedActionPolicy": {
          "action": "release_monitor",
          "authority": "auto_allowed",
          "risk": "low"
        },
        "nextPollSeconds": 0,
        "quietForSeconds": 0,
        "quietThresholdSeconds": 0,
        "stuckRisk": "low",
        "cleanup": "release",
        "nextActionCode": "no_action",
        "humanAction": null,
        "activeStep": null
